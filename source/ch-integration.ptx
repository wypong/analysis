<?xml version="1.0" encoding="UTF-8"?>

<chapter xml:id="ch-integration" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Integration</title>

  <xi:include href="sec-definitions-and-examples-of-integration.ptx" />
  <xi:include href="sec-properties-of-riemann-integrals.ptx" />
  <xi:include href="sec-fundamental-theorem-of-calculus.ptx" />
  <xi:include href="sec-integration-by-parts-and-change-of-variables.ptx" />

  <exercises xml:id="ex-ch7">
    <title>Exercises</title>

    <exercise xml:id="ex-integration-x-squared-uniform-partitions">
      <statement>
        <p>
          Let <m>f(x)=x^2</m> on <m>[0,1]</m>, and let
          <m>P_n=\{0,\frac{1}{n},\frac{2}{n},\dots,1\}</m>.
        </p>
        <ol>
          <li>
            <p>
              Compute <m>L(P_n,f)</m> and <m>U(P_n,f)</m>.
            </p>
          </li>
          <li>
            <p>
              Show that <m>U(P_n,f)-L(P_n,f)\to 0</m>.
            </p>
          </li>
          <li>
            <p>
              Conclude that <m>f</m> is Riemann integrable on <m>[0,1]</m> and
              that
              <me>
                \int_0^1 x^2\,dx=\frac13.
              </me>
            </p>
          </li>
        </ol>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-step-function-piecewise">
      <statement>
        <p>
          Define <m>s \colon [0,3] \to \R</m> by
          <me>
            s(x)=
            \begin{cases}
              1 &amp; \text{if } 0 \le x \lt 1,\\
              -2 &amp; \text{if } 1 \le x \lt 2,\\
              3 &amp; \text{if } 2 \le x \le 3.
            \end{cases}
          </me>
          Show that <m>s</m> is Riemann integrable and compute
          <me>
            \int_0^3 s(x)\,dx.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-dirichlet-not-integrable">
      <statement>
        <p>
          Prove directly from the definitions that the Dirichlet function
          <m>1_{\Q}</m> on <m>[0,1]</m> is not Riemann integrable.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-floor-function">
      <statement>
        <p>
          Show that the function <m>f(x)=\lfloor x \rfloor</m> is Riemann
          integrable on <m>[0,3]</m>, and compute
          <me>
            \int_0^3 \lfloor x \rfloor\,dx.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-finitely-many-nonzero-points">
      <statement>
        <p>
          Let <m>f \colon [a,b] \to \R</m> be bounded, and suppose that
          <m>f(x)=0</m> except at finitely many points of <m>[a,b]</m>. Prove
          that <m>f \in R[a,b]</m> and that
          <me>
            \int_a^b f(x)\,dx=0.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-nonnegative-continuous-zero-integral">
      <statement>
        <p>
          Let <m>f \colon [a,b] \to \R</m> be continuous and suppose that
          <m>f(x) \ge 0</m> for every <m>x \in [a,b]</m>. Prove that if
          <me>
            \int_a^b f(x)\,dx=0,
          </me>
          then <m>f(x)=0</m> for all <m>x \in [a,b]</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-indefinite-integral-absolute-value">
      <statement>
        <p>
          Define <m>F \colon [-1,1] \to \R</m> by
          <me>
            F(x)=\int_0^x |t|\,dt.
          </me>
          Find an explicit formula for <m>F(x)</m> and verify that
          <m>F'(x)=|x|</m> for every <m>x \in [-1,1]</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-indefinite-integral-signum">
      <statement>
        <p>
          Let <m>f(x)=\operatorname{sgn}(x)</m> on <m>[-1,1]</m>, and define
          <me>
            F(x)=\int_0^x f(t)\,dt.
          </me>
          Compute <m>F(x)</m> explicitly. Show that <m>F</m> is continuous on
          <m>[-1,1]</m>, and explain why <m>F</m> is not differentiable at
          <m>0</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-by-parts-zero-boundary">
      <statement>
        <p>
          Suppose <m>F</m> is differentiable on <m>[a,b]</m>, that
          <m>F' \in R[a,b]</m>, and that <m>F(a)=F(b)=0</m>. Prove that
          <me>
            \int_a^b xF'(x)\,dx=-\int_a^b F(x)\,dx.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-by-parts-power-integral">
      <statement>
        <p>
          Use <xref ref="prop-integration-by-parts"/> to prove by induction on
          <m>n \in \N</m> that
          <me>
            \int_0^1 x^n\,dx=\frac{1}{n+1}.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-change-of-variables-polynomial">
      <statement>
        <p>
          Use <xref ref="thm-change-of-variables"/> to compute
          <me>
            \int_0^1 x(1+x^2)^4\,dx.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-change-of-variables-closed-loop">
      <statement>
        <p>
          Let <m>\varphi \in C^1[a,b]</m>, and let <m>f</m> be continuous on
          <m>\varphi([a,b])</m>. Prove that if <m>\varphi(a)=\varphi(b)</m>,
          then
          <me>
            \int_a^b f(\varphi(x))\varphi'(x)\,dx=0.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-countably-many-discontinuities">
      <statement>
        <p>
          Let <m>f \colon [a,b] \to \R</m> be bounded, and suppose that
          <m>f</m> is continuous except at countably many points of
          <m>[a,b]</m>. Use <xref ref="thm-lebesgue-integrability-criterion"/>
          to prove that <m>f</m> is Riemann integrable.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-integration-thomae-weighted-zero">
      <statement>
        <p>
          Let <m>h</m> be the Thomae function on <m>[0,1]</m>. Prove that the
          function <m>x \mapsto xh(x)</m> is Riemann integrable and that
          <me>
            \int_0^1 xh(x)\,dx=0.
          </me>
        </p>
      </statement>
    </exercise>
  </exercises>
</chapter>
