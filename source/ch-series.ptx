<?xml version="1.0" encoding="UTF-8"?>

<chapter xml:id="ch-series" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Series</title>

  <xi:include href="sec-series.ptx" />
  <xi:include href="sec-convergence-tests-for-series.ptx" />
  <xi:include href="sec-more-convergence-tests-for-series.ptx" />

  <exercises xml:id="ex-ch3">
    <title>Exercises</title>

    <exercise xml:id="ex-series-geometric-basic">
      <statement>
        <p>
          Determine whether each of the following series converges. If it
          converges, find its sum.
        </p>
        <p>
          a) <m>\sum_{n=0}^\infty (2/3)^n</m><m>\qquad</m>
          b) <m>\sum_{n=0}^\infty (-1/4)^n</m><m>\qquad</m>
          c) <m>\sum_{n=0}^\infty (-2)^n</m>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-comparison-quadratic">
      <statement>
        <p>
          Use the comparison test to prove that
          <me>
            \sum_{n=1}^\infty \frac{1}{n^2+1}
          </me>
          converges.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-p-test-examples">
      <statement>
        <p>
          Determine whether each series converges or diverges.
        </p>
        <p>
          a) <m>\sum_{n=1}^\infty 1/\sqrt{n}</m><m>\qquad</m>
          b) <m>\sum_{n=1}^\infty 1/n^{3/2}</m><m>\qquad</m>
          c) <m>\sum_{n=1}^\infty 1/n^{-2}</m>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-limit-comparison-cubic">
      <statement>
        <p>
          Use the limit comparison test to determine whether
          <me>
            \sum_{n=2}^\infty \frac{1}{n^3-1}
          </me>
          converges.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-absolute-conditional-classification">
      <statement>
        <p>
          Determine whether each series is absolutely convergent,
          conditionally convergent, or divergent.
        </p>
        <p>
          a) <m>\sum_{n=1}^\infty (-1)^{n+1}/\sqrt{n}</m><m>\qquad</m>
          b) <m>\sum_{n=1}^\infty (-1)^n/n^2</m><m>\qquad</m>
          c) <m>\sum_{n=1}^\infty (-1)^n</m>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-ratio-test-polynomial-over-exponential">
      <statement>
        <p>
          Use the ratio test to prove that
          <me>
            \sum_{n=1}^\infty \frac{n^2}{2^n}
          </me>
          converges absolutely.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-ratio-test-factorial-over-exponential">
      <statement>
        <p>
          Use the ratio test to show that
          <me>
            \sum_{n=1}^\infty \frac{n!}{3^n}
          </me>
          diverges.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-root-test-nth-power">
      <statement>
        <p>
          Use the root test to determine whether
          <me>
            \sum_{n=1}^\infty \left(\frac{3n}{4n+1}\right)^n
          </me>
          converges.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-root-test-inconclusive">
      <statement>
        <p>
          Give two series <m>\sum x_n</m> and <m>\sum y_n</m> such that
          <m>\lim |x_n|^{1/n}=1=\lim |y_n|^{1/n}</m>, but
          <m>\sum x_n</m> converges and <m>\sum y_n</m> diverges.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-alternating-harmonic-error">
      <statement>
        <p>
          Let
          <me>
            s=\sum_{n=1}^\infty \frac{(-1)^{n+1}}{n}.
          </me>
          Find <m>N</m> such that
          <me>
            \left|s-\sum_{n=1}^N \frac{(-1)^{n+1}}{n}\right| \lt 0.01.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-cauchy-product-geometric">
      <statement>
        <p>
          Let <m>|x|&lt;1</m>. Compute the Cauchy product of
          <m>\sum_{n=0}^\infty x^n</m> with itself and use
          <xref ref="thm-mertens-series"/> to prove that
          <me>
            \sum_{n=0}^\infty (n+1)x^n=\frac{1}{(1-x)^2}.
          </me>
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-series-raabe-p-series">
      <statement>
        <p>
          Use the limit form of Raabe's test
          (<xref ref="cor-raabe-limit-form-series"/>) to give another proof
          that
          <me>
            \sum_{n=1}^\infty \frac{1}{n^p}
          </me>
          converges for <m>p&gt;1</m> and diverges for <m>p&lt;1</m>.
          Explain why the case <m>p=1</m> is inconclusive for Raabe's test.
        </p>
      </statement>
    </exercise>
  </exercises>
</chapter>
