<?xml version="1.0" encoding="UTF-8"?>

<chapter xml:id="ch-sequences" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Sequences</title>

  <xi:include href="sec-sequences.ptx" />
  <xi:include href="sec-convergence-tests-for-sequences.ptx" />
  <xi:include href="sec-bolzano-weierstrass.ptx" />
  <xi:include href="sec-cauchy-sequences.ptx" />

  <exercises xml:id="ex-ch2">
    <title>Exercises</title>

    <exercise xml:id="ex-sequences-null-basic">
      <statement>
        <p>
          Prove directly from the definition that <m>(1/n)</m> is a null
          sequence.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-monotone-bounded-convergent">
      <statement>
        <p>
          Let <m>x_n=1-1/n</m>. Show that <m>(x_n)</m> is increasing and
          converges. Find its limit.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-squeeze">
      <statement>
        <p>
          Use the squeeze lemma to prove that
          <m>\sin(n)/n\to 0</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-subsequence-divergent-example">
      <statement>
        <p>
          Give a divergent sequence that has a convergent subsequence.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-limsup-liminf-bounded-examples">
      <statement>
        <p>
          For each of the following sequences, compute its limit superior and
          limit inferior.
        </p>
        <ul>
          <li><m>((-1)^n)</m></li>
          <li><m>(1/n)</m></li>
          <li><m>((-1)^n/n)</m></li>
          <li><m>((-1/2)^n)</m></li>
          <li><m>((-1)^n(1-1/n))</m></li>
        </ul>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-limsup-liminf-unbounded-examples">
      <statement>
        <p>
          Compute the limit superior and limit inferior, in the extended real
          numbers, of each of the following sequences.
        </p>
        <ul>
          <li><m>((-2)^n)</m></li>
          <li><m>(5(n+1))</m></li>
        </ul>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-limsup-liminf-subsequences-example">
      <statement>
        <p>
          Consider the sequence <m>x_n = (-1)^n(1-1/n)</m>.
        </p>
        <p>
          Find a subsequence converging to <m>\limsup x_n</m> and a subsequence
          converging to <m>\liminf x_n</m>. Determine all limits of convergent
          subsequences of <m>(x_n)</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-unique-subsequential-limit">
      <statement>
        <p>
          Let <m>(x_n)</m> be a bounded sequence. Suppose every convergent
          subsequence of <m>(x_n)</m> has the same limit <m>L</m>. Prove that
          <m>(x_n)</m> converges to <m>L</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-cauchy-direct">
      <statement>
        <p>
          Prove directly from the definition that <m>(1/n)</m> is a Cauchy
          sequence.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-cauchy-subsequence">
      <statement>
        <p>
          Prove that every subsequence of a Cauchy sequence is Cauchy.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-bounded-not-cauchy">
      <statement>
        <p>
          Give an example of a bounded sequence that is not Cauchy. Justify
          your answer.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-q-not-sequentially-complete">
      <statement>
        <p>
          Let <m>x_n</m> be the decimal truncation of <m>\sqrt{2}</m> to
          <m>n</m> decimal places:
          <m>1, 1.4, 1.41, 1.414, \dots</m>.
          Show that <m>(x_n)</m> is Cauchy in <m>\Q</m>. Explain why it does
          not converge in <m>\Q</m>, and conclude that <m>\Q</m> is not
          sequentially complete.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-geometric-negative-base">
      <statement>
        <p>
          Determine whether each sequence converges. If it does, find its
          limit.
        </p>
        <ul>
          <li><m>((-1/3)^n)</m></li>
          <li><m>((-2)^n)</m></li>
          <li><m>((3/2)^n)</m></li>
        </ul>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-ratio-test-power-over-exponential">
      <statement>
        <p>
          Use the ratio test to prove that <m>n^3/2^n\to 0</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-ratio-test-factorial">
      <statement>
        <p>
          Use the ratio test to prove that <m>5^n/n!\to 0</m>.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="ex-sequences-ratio-test-inconclusive">
      <statement>
        <p>
          Give two sequences of nonzero real numbers <m>(x_n)</m> and
          <m>(y_n)</m> such that
          <m>|x_{n+1}|/|x_n|\to 1</m> and <m>|y_{n+1}|/|y_n|\to 1</m>, but
          <m>(x_n)</m> is null while <m>(y_n)</m> is unbounded.
        </p>
      </statement>
    </exercise>
  </exercises>
</chapter>
